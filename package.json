{
	"name": "n8n-nodes-picnode",
	"version": "0.1.0",
	"description": "An n8n community node for temporarily hosting images and videos with Picnode.",
	"license": "MIT",
	"homepage": "https://github.com/Nodstriker/n8n-nodes-picnode#readme",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"picnode",
		"image-hosting",
		"video-hosting"
	],
	"author": {
		"name": "Daniel Ramirez Mendoza",
		"email": "danramzdev@pm.me"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nodstriker/n8n-nodes-picnode.git"
	},
	"bugs": {
		"url": "https://github.com/Nodstriker/n8n-nodes-picnode/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22.22"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "vitest run",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PicnodeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Picnode/Picnode.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.40.2",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
